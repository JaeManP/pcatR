\name{pcatR-package}
\alias{pcatR-package}
\alias{pcatR}
\docType{package}
\title{pcatR: Analyze Pragmatic Context Assessment Tool Data}
\description{
Tools for importing, validating, classifying, summarizing, comparing, and
visualizing responses to the 14-item Pragmatic Context Assessment Tool (pCAT).
The package preserves the separate direction and effect responses and does not
calculate or claim a validated total scale score.
}
\details{
The package supports the original CFIR mapping, the updated 2022 CFIR mapping,
team agreement diagnostics, repeated assessments, barrier-focused action-plan
tables, and an optional Shiny analysis dashboard.
}
\seealso{
\code{\link{pcat_items}}, \code{\link{pcat_validate}},
\code{\link{pcat_classify}}, and \code{\link{pcat_summarise}}.
}
