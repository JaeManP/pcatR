\name{pcat_write_analysis}
\alias{pcat_write_analysis}
\alias{pcat_save_profile_pdf}
\title{Export pCAT analysis results and profile figures}
\usage{
pcat_write_analysis(
  x,
  path,
  overwrite = FALSE,
  include_profile_pdf = TRUE,
  include_classified = TRUE,
  profile_label = c(
    "cfir_original_construct", "cfir_2022_construct", "item_text", "item_id"
  )
)

pcat_save_profile_pdf(
  data,
  path,
  group_vars = NULL,
  overwrite = FALSE,
  width = 11,
  height = 8.5,
  title_prefix = "pCAT profile",
  ...
)
}
\arguments{
\item{x}{A \code{pcat_analysis} object returned by \code{pcat_analyse()}.}
\item{path}{Output directory for \code{pcat_write_analysis()} or output PDF
path for \code{pcat_save_profile_pdf()}.}
\item{overwrite}{Logical; replace files previously generated by pcatR in the
output directory. Unrelated files are retained.}
\item{include_profile_pdf}{Logical; include a multi-page profile PDF in the
analysis export.}
\item{include_classified}{Logical; write respondent-item classifications to
\code{02_classified_responses.csv}. Set to \code{FALSE} when a response-level
file is unnecessary or should not be distributed.}
\item{profile_label}{Item-label field used in the exported profile PDF.}
\item{data}{Raw, validated, or classified pCAT data.}
\item{group_vars}{Grouping columns defining one PDF page.}
\item{width, height}{PDF page dimensions in inches.}
\item{title_prefix}{Prefix used in profile page titles.}
\item{...}{Additional arguments passed to \code{plot_pcat_profile()}.}
}
\description{
\code{pcat_write_analysis()} writes a reproducible directory containing an
analysis manifest, validation findings, optional classified responses, item
summaries, consensus diagnostics, an optional action-plan worksheet, analysis
settings, session information, and an optional profile PDF.
\code{pcat_save_profile_pdf()} places one grouping combination on each page.
It validates every page before writing a temporary PDF and replaces the target
only after the complete temporary file is nonempty.
}
\details{
If summary tables were created with \code{suppress_below}, the classified
response file and profile PDF do not automatically inherit that suppression.
Review respondent-level and graphical outputs under the applicable privacy and
disclosure rules before dissemination. When \code{overwrite = TRUE}, only
known files generated by \code{pcat_write_analysis()} are removed before the
new export is written. If profile-page construction or writing fails,
\code{pcat_save_profile_pdf()} identifies the affected group, removes its
temporary file, and leaves any existing target unchanged.
}
\value{The normalized output directory or file path, invisibly.}
\examples{
analysis <- pcat_analyse(
  pcat_example_data(),
  group_vars = c("site_id", "timepoint"),
  validation_action = "none"
)

\dontrun{
pcat_write_analysis(
  analysis,
  path = "pcat_analysis_outputs",
  overwrite = TRUE,
  include_classified = FALSE
)

pcat_save_profile_pdf(
  analysis$classified,
  path = "pcat_profiles.pdf",
  group_vars = c("site_id", "timepoint"),
  overwrite = TRUE
)
}
}
